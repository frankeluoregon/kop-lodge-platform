---
import AdminForm from "../../../../../layouts/AdminForm.astro";
import { getLodgeBySlug, makeRoomForOrder } from "../../../../../lib/db";
import OfficerForm from "../../../../../components/admin/forms/OfficerForm";

const lodgeSlug = Astro.params.lodge!;
const env = Astro.locals.runtime.env;

const lodge = await getLodgeBySlug(env.DB, lodgeSlug);
if (!lodge) return Astro.redirect("/", 302);

const id = Number(new URL(Astro.request.url).searchParams.get("id"));
if (!id) return Astro.redirect(`/lodges/admin/${lodgeSlug}`, 302);

const officer = await env.DB.prepare("SELECT * FROM officers WHERE id = ? AND lodge_id = ?").bind(id, lodge.id).first<Record<string, unknown>>();
if (!officer) return Astro.redirect(`/lodges/admin/${lodgeSlug}`, 302);

if (Astro.request.method === "POST") {
  const wantsJson = Astro.request.headers.get("Accept")?.includes("application/json");
  const form = await Astro.request.formData();
  if (form.get("_action") === "delete") {
    await env.DB.prepare("DELETE FROM officers WHERE id = ? AND lodge_id = ?").bind(id, lodge.id).run();
    const deleteUrl = `/lodges/admin/${lodgeSlug}`;
    if (wantsJson) return new Response(JSON.stringify({ redirect: deleteUrl }), { headers: { "Content-Type": "application/json" } });
    return Astro.redirect(deleteUrl, 302);
  }
  try {
    let photoKey = form.get("photo_key")?.toString() ?? "";

    const photo = form.get("photo");
    if (photo instanceof File && photo.size > 0) {
      const safeName = photo.name.replace(/[^a-zA-Z0-9._-]/g, "_");
      const r2Key = `officers/${lodgeSlug}/${Date.now()}-${safeName}`;
      await env.MEDIA.put(r2Key, photo.stream(), {
        httpMetadata: { contentType: photo.type },
      });
      photoKey = `/media/${r2Key}`;
    }

    const now = new Date().toISOString();
    const order = Number(form.get("display_order") ?? 0);
    await makeRoomForOrder(env.DB, "officers", lodge.id, order, id);
    await env.DB.prepare(
      "UPDATE officers SET title=?,name=?,email=?,photo_key=?,display_order=?,active=?,updated_at=? WHERE id=? AND lodge_id=?"
    ).bind(
      form.get("title")?.toString() ?? "",
      form.get("name")?.toString() ?? "",
      form.get("email")?.toString() || null,
      photoKey || null,
      order,
      form.get("active") === "1" ? 1 : 0,
      now, id, lodge.id,
    ).run();
    if (wantsJson) return new Response(JSON.stringify({ redirect: `/lodges/admin/${lodgeSlug}` }), { headers: { "Content-Type": "application/json" } });
  } catch (e: unknown) {
    const msg = `Error: ${e instanceof Error ? e.message : String(e)}`;
    if (wantsJson) return new Response(JSON.stringify({ error: msg }), { status: 400, headers: { "Content-Type": "application/json" } });
  }
}
---

<AdminForm title="Edit Officer" lodgeSlug={lodgeSlug}>
  <OfficerForm
    client:only="react"
    cancelUrl={`/lodges/admin/${lodgeSlug}`}
    isEdit
    initialData={{
      title: String(officer.title ?? ""),
      name: String(officer.name ?? ""),
      email: String(officer.email ?? ""),
      display_order: Number(officer.display_order ?? 0),
      active: Boolean(officer.active),
      photo_key: String(officer.photo_key ?? ""),
    }}
  />
</AdminForm>
